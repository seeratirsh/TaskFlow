<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Status update via AJAX
    document.querySelectorAll('.status-select').forEach(select => {
      select.addEventListener('change', async function() {
        const taskId = this.dataset.taskId;
        const status = this.value;
        const badge = document.getElementById('badge-' + taskId);
        try {
          const res = await fetch(`/tasks/${taskId}/status`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status })
          });
          const data = await res.json();
          if (data.success && badge) {
            badge.textContent = data.status;
            badge.className = 'badge status-badge ' + getStatusClass(data.status);
          }
        } catch(e) { console.error(e); }
      });
    });

    function getStatusClass(status) {
      const map = { 'Todo': 'bg-secondary', 'In Progress': 'bg-warning text-dark', 'Completed': 'bg-success', 'Overdue': 'bg-danger' };
      return map[status] || 'bg-secondary';
    }
  </script>
</body>
</html>
